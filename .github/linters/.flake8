[flake8]
# https://black.readthedocs.io/en/stable/guides/using_black_with_other_tools.html#flake8
extend-ignore = E203,W503
max-line-length = 88
per-file-ignores =
    # probes.py contains embedded bash scripts in multi-line strings; the bash
    # lines are intentionally long and cannot be wrapped without breaking the
    # script logic.
    probes.py:E501
